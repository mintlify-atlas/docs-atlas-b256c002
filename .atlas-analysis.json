  "keyFeatures": [
    "Real-time CPU usage monitoring with configurable polling rates",
    "Real-time RAM usage monitoring with configurable polling rates",
    "VM lifecycle management (create, delete, rename)",
    "JSON-based VM configuration storage",
    "Interactive CLI interface for all operations",
    "Cross-platform system stats via gopsutil"
  ],
  "publicApiSurface": [
    "cpuwatcher.WatchCPU()",
    "cpuwatcher.CPUSetPollingRate(rate float64)",
    "ramwatcher.WatchRAM()",
    "ramwatcher.RAMSetPollingRate(rate float64)",
    "vmwatcher.VMRunningStatus()",
    "vmwatcher.VMResourceAllocation()",
    "vmactions.VMCreate()",
    "vmactions.VMDelete()",
    "vmactions.VMManage()",
    "vmactions.VMRename()"

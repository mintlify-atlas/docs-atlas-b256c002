{
  "projectType": "cli-tool",
  "projectName": "Stratosphere Core",
  "projectDescription": "A Go-based CLI tool for managing virtual environments, providing system resource monitoring and VM lifecycle management as the foundation for the Stratosphere virtualization platform.",
  "theme": "aspen",
  "primaryColor": "#5c64f4",
  "lightColor": "#acb4fc",
